<%
// Пример вызова в шаблоне (EJS):
//
// <\%- include('externe/components/media/Carousel/Carousel.ejs', { 
//	carousel_component: {
//		this: {
//			parent: 'parentClass',
//			block: 'childBlockClass',
//			class: ['childClass'],
//			id: ['childID'],
//			tag: 'div',
//			style: ['customStyle'],
//			dataAttribute: ['customDataAttributes'], 
//		},
//		list: [
//			{image_component: {}, content: {}}
//		]
//	}
//}) %>
%>
<%
	if(
		(typeof carousel_component === 'undefined' || !carousel_component) || 
		(typeof carousel_component.list === 'undefined' && !carousel_component.list)
	) {
		return
	}

	var {blockClass, thisClass, thisID, thisTag, thisStyles, thisDataAttributes} = externe.setupEJSComponent({...carousel_component.this, componentName: 'carousel'})
	
	thisTag = 'article'
%>


<<%=thisTag%> data-fsc-carousel <%-thisDataAttributes%> class='<%=thisClass%>' <%-thisID%> <%-thisStyles%>>

		<ul class="<%=blockClass%>__list" data-fsc-carousel-list>
			<% for (var carousel of carousel_component.list) { %>
				<li class="<%=blockClass%>__element" data-fsc-carousel-item>

					<% if(carousel.content) { content = carousel.content %>
						<div class="<%=blockClass%>__container container">
							<h1 class="<%=blockClass%>__title">
								<%= content.title%>
							</h1>

							<div class="<%=blockClass%>__body">
								<div class="<%=blockClass%>__text">
									<% for (var text of content.text) { %>
										<p><%=text%></p>
									<% } %>
								</div>

								<%- include('src/ejs/components/button.ejs', {
									button_component: content.button_component
								}) %>
							</div>

						</div>
					<% } %>
					
					<%- include('externe/components/media/Image/Image.ejs', {
						image_component: carousel.image_component
					}) %>

					
				
				</li>
			<% } %>
		</ul>
		
		<% subBlockClass = 'controls-carousel' %> 
		<div class="<%=blockClass%>__controls <%=subBlockClass%>">
			<div class="<%=subBlockClass%>__wrapper">
				<button class="<%=subBlockClass%>__control" data-fsc-carousel-button-left></button>
				<button class="<%=subBlockClass%>__control" data-fsc-carousel-button-right></button>
			</div>
		</div>

		<% subBlockClass = 'dots-carousel' %> 
		<div class="<%=blockClass%>__dots <%=subBlockClass%>">
			<ul class="<%=subBlockClass%>__list" data-fsc-carousel-dots>
				<% for (var i = 0; i < carousel_component.list.length; i++) { %>
					<li class="<%=subBlockClass%>__element" data-fsc-carousel-dot>
						<button class="<%=subBlockClass%>__button">
							<span class="<%=subBlockClass%>__dot"></span>
						</button>
					</li>
				<% } %>
			</ul>
		</div>
		
		<div class="<%=blockClass%>__counter">
			<span data-fsc-carousel-timer></span>
			<span data-fsc-carousel-counter></span>
		</div>
		
</<%=thisTag%>>