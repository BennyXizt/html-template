{
  "name": "htmltemplate",
  "private": true,
  "version": "2.1.3",
  "type": "module",
  "scripts": {
    "dev": "tsx ./externe/plugins/trackTime/trackTime.ts",
    "dev:notrack": "concurrently \"vite\" \"npm run server\"",
    "server": "php -S localhost:8000 -t ./externe/php",
    "online": "concurrently \"vite --host\" \"npm run server\"",
    "build": "vite build",
    "preview": "npm run build && vite preview --host",
    "component": "tsx ./externe/plugins/createElements/create-new-component.ts",
    "section": "tsx ./externe/plugins/createElements/create-new-section.ts",
    "page": "tsx ./externe/plugins/createElements/create-new-page.ts",
    "delete": "tsx ./externe/plugins/createElements/delete-element.ts",
    "video": "tsx ./externe/plugins/convertMedia/convertVideo/convert-video.ts"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^24.13.2",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "dotenv": "^17.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "sass": "^1.89.2",
    "sharp": "^0.34.5",
    "tsx": "^4.20.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-ejs": "^1.7.0",
    "vite-plugin-qrcode": "^0.3.0"
  }
}